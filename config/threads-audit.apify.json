{
  "actorId": "futurizerush/meta-threads-scraper",
  "input": {
    "mode": "search",
    "keywords": [
      "마케팅",
      "광고비",
      "AI 마케팅"
    ],
    "search_filter": "top",
    "start_date": "1 month",
    "max_posts": 10
  },
  "thresholds": {
    "minLikes": 50,
    "minReplies": 30,
    "minViews": 5000,
    "minShareOrRepost": 40
  },
  "detailEnrichment": {
    "enabled": true,
    "actorId": "trantus/threads-post-scraper",
    "maxItems": 8,
    "input": {
      "raw": false
    }
  },
  "output": {
    "maxItems": 50,
    "maxKeywords": 3,
    "auditDir": "docs/reference-data",
    "maxFullTextChars": 1200,
    "writeDetailJson": true
  }
}
